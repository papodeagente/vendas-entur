generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           Int      @id @default(autoincrement())
  email        String   @unique
  nome         String
  passwordHash String   @map("password_hash")
  role         String   @default("user") // admin | user
  ativo        Boolean  @default(true)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  sessoes      Sessao[]
  pacotes      Pacote[]

  @@map("users")
}

model Configuracao {
  id        Int      @id @default(autoincrement())
  chave     String   @unique // openai_api_key | anthropic_api_key | ai_provider_padrao | modelo_openai | modelo_anthropic
  valor     String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("configuracoes")
}

model Pacote {
  id              Int      @id @default(autoincrement())
  nome            String   // ex: "Cancun 7 dias All Inclusive"
  destino         String   // ex: "Cancun, México"
  tipo            String   // praia | aventura | cultural | romance | familia | luxo | outro
  duracaoDias     Int      @map("duracao_dias")
  valorTotal      Float    @map("valor_total")
  moeda           String   @default("BRL")
  personaAlvo     String   @map("persona_alvo") // ex: "casal sem filhos, 30-45 anos"
  descricao       String   @db.Text // hotel, atividades, refeições, diferenciais
  diferenciais    String?  @db.Text // o que torna esse pacote especial
  objecoesComuns  String?  @db.Text @map("objecoes_comuns") // o que clientes costumam objetar
  observacoes     String?  @db.Text // notas livres do vendedor
  createdById     Int      @map("created_by_id")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  createdBy       User     @relation(fields: [createdById], references: [id])
  sessoes         Sessao[]

  @@map("pacotes")
}

model Sessao {
  id            Int       @id @default(autoincrement())
  userId        Int?      @map("user_id")
  modeloSpin    String    @default("entur_crm_interno") @map("modelo_spin") // entur_crm_interno | agencia_buenos_aires
  agenciaNome   String    @map("agencia_nome")
  vendedorNome  String    @map("vendedor_nome")
  status        String    @default("rascunho") // rascunho | completa
  comercialStatus String  @default("nova") @map("comercial_status") // nova | diagnostico | demo | proposta | piloto | negociacao | ganho | perdido
  ctaEscolhido  String?   @map("cta_escolhido") // demo | proposta | piloto
  precoCrmMes   Float?    @map("preco_crm_mes")
  valorMesaMes  Float?    @map("valor_mesa_mes")
  valorMesaAno  Float?    @map("valor_mesa_ano")
  followUpEm    DateTime? @map("follow_up_em")
  observacaoFechamento String? @map("observacao_fechamento")
  pacoteId      Int?      @map("pacote_id")
  perguntasJson String?   @db.Text @map("perguntas_json") // SPIN gerado por IA (JSON)
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  usuario       User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  pacote        Pacote?   @relation(fields: [pacoteId], references: [id], onDelete: SetNull)
  respostas     RespostaDiagnostico[]
  dados         DadosAgencia?
  planoAcoes    PlanoAcao[]
  prospect      Prospect?
  frases        FraseCliente[]
  progresso     ProgressoFase[]

  @@map("sessoes")
}

model Prospect {
  id            Int     @id @default(autoincrement())
  sessaoId      Int     @unique @map("sessao_id")
  nome          String
  cargo         String?
  tamanhoEquipe Int?    @map("tamanho_equipe")
  email         String?
  whatsapp      String?

  sessao        Sessao  @relation(fields: [sessaoId], references: [id], onDelete: Cascade)

  @@map("prospects")
}

model FraseCliente {
  id        Int      @id @default(autoincrement())
  sessaoId  Int      @map("sessao_id")
  fase      String   // situacao | problema | implicacao | needPayoff
  texto     String
  perguntaId Int?    @map("pergunta_id")
  createdAt DateTime @default(now()) @map("created_at")

  sessao    Sessao   @relation(fields: [sessaoId], references: [id], onDelete: Cascade)

  @@map("frases_cliente")
}

model ProgressoFase {
  id          Int       @id @default(autoincrement())
  sessaoId    Int       @map("sessao_id")
  fase        String    // abertura | situacao | problema | implicacao | needPayoff | fechamento
  iniciadaEm  DateTime? @map("iniciada_em")
  concluidaEm DateTime? @map("concluida_em")

  sessao      Sessao    @relation(fields: [sessaoId], references: [id], onDelete: Cascade)

  @@unique([sessaoId, fase])
  @@map("progresso_fases")
}

model RespostaDiagnostico {
  id          Int     @id @default(autoincrement())
  sessaoId    Int     @map("sessao_id")
  perguntaId  Int     @map("pergunta_id")
  resposta    Boolean
  severidade  Int?    // 1 = dor forte (sem processo), 2 = dor média (processo parcial), null = resolvido

  sessao      Sessao  @relation(fields: [sessaoId], references: [id], onDelete: Cascade)

  @@unique([sessaoId, perguntaId])
  @@map("respostas_diagnostico")
}

model DadosAgencia {
  id              Int    @id @default(autoincrement())
  sessaoId        Int    @unique @map("sessao_id")
  vendasMes       Int    @map("vendas_mes")
  ticketMedio     Float  @map("ticket_medio")
  comissaoPct     Float  @map("comissao_pct")
  atendPerdidos   Int    @map("atend_perdidos")
  clientesAtivos  Int    @map("clientes_ativos")
  clientesInativos Int   @map("clientes_inativos")
  indicacoesMes   Int    @map("indicacoes_mes")
  taxaConversao   Float  @map("taxa_conversao")
  tempoRecompra   Int    @map("tempo_recompra") // em meses
  cpl             Float  @default(0) // custo por lead
  ticket2aCompra  Float  @default(0) @map("ticket_2a_compra")
  historicoMeses  Int    @default(12) @map("historico_meses")

  sessao          Sessao @relation(fields: [sessaoId], references: [id], onDelete: Cascade)

  @@map("dados_agencia")
}

model PlanoAcao {
  id          Int       @id @default(autoincrement())
  sessaoId    Int       @map("sessao_id")
  acaoId      Int       @map("acao_id")
  concluida   Boolean   @default(false)
  concluidaEm DateTime? @map("concluida_em")

  sessao      Sessao    @relation(fields: [sessaoId], references: [id], onDelete: Cascade)

  @@unique([sessaoId, acaoId])
  @@map("plano_acoes")
}

model Benchmark {
  id              Int    @id @default(autoincrement())
  chave           String @unique
  valorSemEntur   Float  @map("valor_sem_entur")
  valorComEntur   Float  @map("valor_com_entur")
  descricao       String

  @@map("benchmarks")
}
